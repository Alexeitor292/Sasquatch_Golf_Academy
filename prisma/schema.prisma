generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  INVENTORY_MANAGER
  SUPPORT
}

enum SiteStatus {
  DRAFT
  LIVE
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
  EMBED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  DRAFT
  OPEN
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentProviderKind {
  STRIPE
  SQUARE
  MANUAL
}

enum PaymentMode {
  TEST
  LIVE
}

enum PaymentTransactionKind {
  AUTHORIZATION
  CAPTURE
  REFUND
  VOID
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  customers     Customer[]
  revisions     PageRevision[]
  auditLogs     AuditLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  sites       Site[]
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Site {
  id               String            @id @default(cuid())
  organizationId   String
  name             String
  slug             String            @unique
  primaryDomain    String?
  status           SiteStatus        @default(DRAFT)
  settings         Json?
  theme            Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages            Page[]
  mediaAssets      MediaAsset[]
  products         Product[]
  inventoryPlaces  InventoryLocation[]
  customers        Customer[]
  orders           Order[]
  paymentProviders PaymentProvider[]
  auditLogs        AuditLog[]
}

model Page {
  id                  String        @id @default(cuid())
  siteId              String
  name                String
  slug                String
  pageType            String        @default("marketing")
  status              PageStatus    @default(DRAFT)
  seo                 Json?
  sortOrder           Int           @default(0)
  publishedRevisionId String?       @unique
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  site                Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  revisions           PageRevision[]
  publishedRevision   PageRevision? @relation("PublishedRevision", fields: [publishedRevisionId], references: [id], onDelete: SetNull)

  @@unique([siteId, slug])
}

model PageRevision {
  id               String   @id @default(cuid())
  pageId           String
  createdById      String?
  version          Int
  title            String
  schemaVersion    Int      @default(1)
  content          Json
  createdAt        DateTime @default(now())
  publishedAt      DateTime?
  page             Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  publishedForPage Page?    @relation("PublishedRevision")

  @@unique([pageId, version])
}

model MediaAsset {
  id         String    @id @default(cuid())
  siteId     String
  kind       MediaKind
  title      String
  altText    String?
  url        String
  storageKey String?
  mimeType   String?
  width      Int?
  height     Int?
  durationMs Int?
  focalX     Float?
  focalY     Float?
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model Product {
  id          String        @id @default(cuid())
  siteId      String
  slug        String
  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  seo         Json?
  options     Json?
  media       Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]
  orderItems  OrderItem[]

  @@unique([siteId, slug])
}

model ProductVariant {
  id               String          @id @default(cuid())
  productId        String
  title            String
  sku              String          @unique
  barcode          String?
  priceCents       Int
  compareAtCents   Int?
  costCents        Int?
  currency         String          @default("USD")
  weightGrams      Int?
  attributes       Json?
  inventoryTracked Boolean         @default(true)
  isDefault        Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLevels  InventoryLevel[]
  orderItems       OrderItem[]
}

model InventoryLocation {
  id              String           @id @default(cuid())
  siteId          String
  name            String
  code            String
  isDefault       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  inventoryLevels InventoryLevel[]

  @@unique([siteId, code])
}

model InventoryLevel {
  id           String            @id @default(cuid())
  variantId    String
  locationId   String
  available    Int               @default(0)
  reserved     Int               @default(0)
  incoming     Int               @default(0)
  reorderPoint Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  variant      ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location     InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([variantId, locationId])
}

model Customer {
  id         String   @id @default(cuid())
  siteId     String
  userId     String?
  email      String
  firstName  String?
  lastName   String?
  phone      String?
  notes      String?
  tags       Json?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders     Order[]

  @@unique([siteId, email])
}

model Order {
  id                String               @id @default(cuid())
  siteId            String
  customerId        String?
  orderNumber       String
  status            OrderStatus          @default(OPEN)
  paymentStatus     String               @default("pending")
  fulfillmentStatus String               @default("unfulfilled")
  currency          String               @default("USD")
  subtotalCents     Int                  @default(0)
  taxCents          Int                  @default(0)
  shippingCents     Int                  @default(0)
  discountCents     Int                  @default(0)
  totalCents        Int                  @default(0)
  shippingAddress   Json?
  billingAddress    Json?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  site              Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  customer          Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          PaymentTransaction[]

  @@unique([siteId, orderNumber])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String?
  variantId       String?
  title           String
  sku             String?
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model PaymentProvider {
  id            String               @id @default(cuid())
  siteId        String
  kind          PaymentProviderKind
  mode          PaymentMode          @default(TEST)
  label         String
  isDefault     Boolean              @default(false)
  config        Json
  webhookSecret String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  site          Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  transactions  PaymentTransaction[]
}

model PaymentTransaction {
  id                String                   @id @default(cuid())
  providerId        String
  orderId           String?
  providerReference String?
  kind              PaymentTransactionKind
  status            PaymentTransactionStatus @default(PENDING)
  amountCents       Int
  currency          String                   @default("USD")
  metadata          Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  provider          PaymentProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  order             Order?                   @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String   @id @default(cuid())
  siteId     String
  actorId    String?
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}
